    "htmx-ext-response-targets": "^2.0.3",
    "htmx.org": "^2.0.4",
    "idiomorph": "^0.7.3",
    "lucide": "^0.483.0",
    "tailwindcss": "^4.0.15"
  },
  "devDependencies": {
    "@parcel/transformer-css": "^2.14.1",
    "@tailwindcss/postcss": "^4.0.15",
    "parcel": "^2.14.1",
    "postcss": "^8.5.3",
    "prettier": "latest",
    "svgo": "^3"
  }
